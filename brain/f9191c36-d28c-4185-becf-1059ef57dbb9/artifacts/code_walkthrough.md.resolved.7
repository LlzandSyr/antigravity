int main(void)
{
	// 中断向量分组配置
	NVIC_PriorityGroupConfig(NVIC_PriorityGroup_2);
	
	// 初始化硬件外设
	usart1_init(115200);   // 有线串口 1
	usart3_init(9600);     // 无线串口 3
	led_init();            // LED2,3,4
	led_pwm_init();        // LED1 (PWM 模式)
	dht11_init();          // DHT11 传感器
	state_exti_init();     // 外部中断 PE6
	
	printf("\r\n--- LLZ 智能控制透传与状态监测系统上电成功 ---\r\n");
	
	// 初始化检查蓝牙物理连接状态 (STATE=PE6) -> 反馈给 D4 (PE14)
	if(PEin(6) == 1)
	{
		PEout(14) = 0; // 亮：已连接
	}
	else
	{
		PEout(14) = 1; // 灭：未连接
	}

	// 执行 Flash 物理读写调试自测
	flash_test();
	
	while(1)
	{
		// 1. 处理串口 1 (PC端) 下发的控制包
		if (g_usart1_ready)
		{
			parse_and_respond((char *)g_usart1_buf, USART1);
			g_usart1_cnt = 0;
			g_usart1_ready = 0;
		}
		
		// 2. 处理串口 3 (无线蓝牙) 下发的控制包
		if (g_usart3_ready)
		{
			parse_and_respond((char *)g_usart3_buf, USART3);
			g_usart3_cnt = 0;
			g_usart3_ready = 0;
		}
	}
}
```


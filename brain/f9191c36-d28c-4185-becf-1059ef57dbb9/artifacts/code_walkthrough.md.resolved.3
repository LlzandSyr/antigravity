### 8. 串口 3（无线蓝牙卡槽）初始化配置 (Lines 150-184)
```c
void usart3_init(uint32_t baud)
{
	// 硬件时钟使能：使能 GPIOB 时钟与挂载在 APB1（低速外设总线）上的 USART3 时钟
	RCC_AHB1PeriphClockCmd(RCC_AHB1Periph_GPIOB,ENABLE);
	RCC_APB1PeriphClockCmd(RCC_APB1Periph_USART3,ENABLE);
	
	// PB10/PB11 配置为复用功能模式 (AF)
	GPIO_InitStructure.GPIO_Pin=GPIO_Pin_10|GPIO_Pin_11;
	GPIO_InitStructure.GPIO_Mode=GPIO_Mode_AF;
	GPIO_InitStructure.GPIO_Speed=GPIO_Low_Speed;
	GPIO_InitStructure.GPIO_OType=GPIO_OType_PP;
	GPIO_InitStructure.GPIO_PuPd=GPIO_PuPd_NOPULL;
	GPIO_Init(GPIOB,&GPIO_InitStructure);	
	
	// 物理映射引脚：PB10 复用为 USART3_TX，PB11 复用为 USART3_RX
	GPIO_PinAFConfig(GPIOB,GPIO_PinSource10,GPIO_AF_USART3);
	GPIO_PinAFConfig(GPIOB,GPIO_PinSource11,GPIO_AF_USART3);	
	
	// 配置协议底层物理波特率
	USART_InitStructure.USART_BaudRate = baud; 					// 波特率：蓝牙默认 9600bps
	USART_InitStructure.USART_WordLength = USART_WordLength_8b;
	USART_InitStructure.USART_StopBits = USART_StopBits_1;
	USART_InitStructure.USART_Parity = USART_Parity_No;
	USART_InitStructure.USART_HardwareFlowControl = USART_HardwareFlowControl_None;
	USART_InitStructure.USART_Mode = USART_Mode_Rx | USART_Mode_Tx;
	USART_Init(USART3, &USART_InitStructure);
	
	// 开启串口 3 接收非空中断 (RXNE)
	USART_ITConfig(USART3,USART_IT_RXNE,ENABLE);
	
	// 配置全局 NVIC 中断嵌套响应分配
	NVIC_InitStructure.NVIC_IRQChannel = USART3_IRQn;
	NVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0; 
	NVIC_InitStructure.NVIC_IRQChannelSubPriority = 0;        
	NVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;           
	NVIC_Init(&NVIC_InitStructure);
	
	// 物理使能使串口 3 正式工作
	USART_Cmd(USART3, ENABLE);
}
```
#### 💡 深度剖析：
*   **APB2 与 APB1 的差异（重要物理细节 ⭐）**：
    *   **`USART1`** 挂载在 **`APB2（Advanced Peripheral Bus 2，第二代高级外设总线）`** 上，主频高达 **`84MHz`**；
    *   **`USART3`** 挂载在 **`APB1（Advanced Peripheral Bus 1，第一代高级外设总线）`** 上，时钟频率只有 **`42MHz`**。
    *   标准固件库的 `USART_Init` 会根据它挂载的总线频率，自动在底层算出对应的分频器值（`USART_BRR` 分频寄存器），为我们直接隔离了这种硬件频率差异！这类似于高级面向对象语言的屏蔽底层多态！


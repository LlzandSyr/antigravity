## 📂 第二部分：核心数据流向源码精讲与“流向注释”

下面我们按照 **数据流动线路**，将散落在代码各处的初始化、中断、主循环与解析部分聚合在一起，边注释流向边深度精讲！

---

### 2.2 数据流向主线一：有线控制流（PC 上位机控制 LED1 占空比）

本主线实现：PC端下发 `duty=50#` ➔ 串口1中断接收 ➔ 前台解析 ➔ 改变 PWM 占空比 ➔ 串口1回送应答。

#### 📥 步骤 1：配置接收数据通道（有线串口 1 初始化）
当有线串口 1 准备就绪时，数据可以通过 `PA10(RX)` 进入单片机：
```c
// 数据流向：外部有线电平 -> PA10 (RX) -> USART1 硬件接收器
void usart1_init(uint32_t baud)
{
	// 1. 开辟 GPIOA 和 USART1 时钟通道
	RCC_AHB1PeriphClockCmd(RCC_AHB1Periph_GPIOA, ENABLE);
	RCC_APB2PeriphClockCmd(RCC_APB2Periph_USART1, ENABLE);
	
	// 2. 引脚物理连接：PA9 为有线发送 TX，PA10 为有线接收 RX
	GPIO_InitStructure.GPIO_Pin = GPIO_Pin_9 | GPIO_Pin_10;
	GPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF; // 复用模式以供串口接管
	GPIO_InitStructure.GPIO_Speed = GPIO_Low_Speed;
	GPIO_InitStructure.GPIO_OType = GPIO_OType_PP;
	GPIO_InitStructure.GPIO_PuPd = GPIO_PuPd_NOPULL;
	GPIO_Init(GPIOA, &GPIO_InitStructure);	
	
	// 3. 建立引脚到串口 1 外设的路由映射
	GPIO_PinAFConfig(GPIOA, GPIO_PinSource9, GPIO_AF_USART1);
	GPIO_PinAFConfig(GPIOA, GPIO_PinSource10, GPIO_AF_USART1);	
	
	// 4. 配置波特率等协议参数
	USART_InitStructure.USART_BaudRate = baud; 					
	USART_InitStructure.USART_WordLength = USART_WordLength_8b;	
	USART_InitStructure.USART_StopBits = USART_StopBits_1;		
	USART_InitStructure.USART_Parity = USART_Parity_No;			
	USART_InitStructure.USART_HardwareFlowControl = USART_HardwareFlowControl_None;
	USART_InitStructure.USART_Mode = USART_Mode_Rx | USART_Mode_Tx;
	USART_Init(USART1, &USART_InitStructure);
	
	// 5. 开启接收中断：有数据流进入触发中断
	USART_ITConfig(USART1, USART_IT_RXNE, ENABLE);
	
	// 6. 配置中断通道，使得数据流能打断主线程
	NVIC_InitStructure.NVIC_IRQChannel = USART1_IRQn;
	NVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;
	NVIC_InitStructure.NVIC_IRQChannelSubPriority = 0;
	NVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;
	NVIC_Init(&NVIC_InitStructure);
	
	USART_Cmd(USART1, ENABLE); // 串口1正式拉起运行
}
```

#### 📥 步骤 2：中断拼装数据流（`USART1_IRQHandler` 中断成包）
字符由上位机串行进入，中断负责将流式字节聚合成包：
```c
// 数据流向：USART1接收寄存器 DR -> 临时变量 d -> 缓冲队列 g_usart1_buf -> 摇红旗就绪
void USART1_IRQHandler(void)
{
	uint8_t d; // 临时承接 1 字节数据流
	if(USART_GetITStatus(USART1, USART_IT_RXNE) == SET)
	{
		d = USART_ReceiveData(USART1); // 【流向】：读取 1 字节，硬件自动清除接收就绪标志
		
		if (g_usart1_ready == 0) // 如果上一个命令包已被主循环处理完
		{
			if (g_usart1_cnt < sizeof(g_usart1_buf) - 1)
			{
				g_usart1_buf[g_usart1_cnt++] = d; // 【流向】：逐字节拼入全局缓冲区，指针 cnt 自动累加右移
				if (d == '#') // 检测到结束符 '#'
				{
					g_usart1_buf[g_usart1_cnt] = '\0'; // 【流向】：追加字符串结束标志，形成合法 C 语言字符串
					g_usart1_ready = 1; // 【流向】：摇起红旗，通知前台主循环有新信件
				}
			}
			else
			{
				g_usart1_cnt = 0; // 溢出防御：直接清空计数指针
			}
		}
		USART_ClearITPendingBit(USART1, USART_IT_RXNE); // 清除中断挂起位
	}
}
```

#### 📥 步骤 3：前台调度与数据解析（`main` 轮询与 `parse_and_respond` 驱动）
前台抓到红旗，拆包解析并调用 PWM 硬件接口：
```c
/* inside main() loop: */
// 数据流向：轮询到 g_usart1_ready == 1 -> 送入解析器 -> 复位计数器与红旗准备接收下一个
while(1)
{
	if (g_usart1_ready)
	{
		parse_and_respond((char *)g_usart1_buf, USART1); // 【流向】：送入解析器，指定回送串口为 USART1
		g_usart1_cnt = 0;   // 【流向】：重置写指针为 0，擦除旧缓冲区
		g_usart1_ready = 0; // 【流向】：放下红旗，解除锁定
	}
}

/* inside parse_and_respond(): */
// 数据流向：指令字符串 -> 提取占空比 -> 改变定时器物理寄存器 CCR1 -> 拼装 duty set ok -> 串口 1 发送
void parse_and_respond(char *cmd, USART_TypeDef* respond_port)
{
	char resp_buf[64] = {0}; // 局部栈空间开辟应答缓冲区
	
	if (strncmp(cmd, "duty=", 5) == 0) // 匹配头部
	{
		int val = 0;
		if (sscanf(cmd, "duty=%d#", &val) == 1) // 【流向】：解析 cmd 字符串，将占空比整数值解析流入 val
		{
			if (val < 0) val = 0;     // 下限过滤
			if (val > 100) val = 100; // 上限过滤
			
			TIM_SetCompare1(TIM14, val); // 【流向】：修改 TIM14_CCR1 寄存器，控制 PF9 低电平脉宽改变亮度！
			
			sprintf(resp_buf, "duty set %d ok\r\n", val); // 【流向】：数据流向 resp_buf 组装为应答格式
			usart_send_string(respond_port, (uint8_t *)resp_buf); // 【流向】：回送给 USART1 发送寄存器 DR
		}
	}
}
```

---

### 2.3 数据流向主线二：无线控制与数据透传流（手机 APP 控制与 PC 端回显）

本主线实现：手机端下发 `duty=50#` ➔ 蓝牙模块无线接收 ➔ 串口 3 中断接收 ➔ **【透传支流】数据立刻实时复制发送给串口 1 供电脑吃瓜回显** ➔ 串口 3 累加成包并由前台解析 ➔ 改变 PWM 占空比 ➔ 串口 3 无线回送应答。

#### 📥 步骤 1：中断数据流分流与实时透传（`USART3_IRQHandler` 核心）
在此中断中，蓝牙流入的每一字节数据会被**克隆复制**，立刻流入有线串口 1 发送给电脑：
```c
// 数据流向：蓝牙接收 -> USART3_DR -> 克隆复制 -> USART1_DR (发送给电脑回显)
// 数据流向：同时 -> g_usart3_buf 缓冲区 -> 检测 '#' 摇起无线红旗 g_usart3_ready = 1
void USART3_IRQHandler(void)
{
	uint8_t d; // 声明单字节流临时承载变量
	if(USART_GetITStatus(USART3, USART_IT_RXNE) == SET)
	{
		d = USART_ReceiveData(USART3); // 【流向】：蓝牙串口 3 读取 1 字节流入 d
		
		// 【透传核心数据流向】：直接克隆数据，强行送入 USART1 发送寄存器！
		// 这样手机上按了什么，PC 调试助手上立刻像数据玻璃一样完全透明回显显示！
		USART_SendData(USART1, d);
		
		if (g_usart3_ready == 0) // 如果蓝牙前一个包已处理完
		{
			if (g_usart3_cnt < sizeof(g_usart3_buf) - 1)
			{
				g_usart3_buf[g_usart3_cnt++] = d; // 【流向】：拼入蓝牙专用接收缓冲区
				
				// 临时终止字符串，用于连接状态的软件双重防身拦截检测
				g_usart3_buf[g_usart3_cnt] = '\0';
				
				// [连接拦截机制] (详情见数据流向主线四)
				if (strstr((char *)g_usart3_buf, "OK+LOST") != NULL)
				{
					PEout(14) = 1;      // 灭灯
					g_usart3_cnt = 0;   // 清空
				}
				else if (strstr((char *)g_usart3_buf, "OK+CONN") != NULL)
				{
					PEout(14) = 0;      // 亮灯
					g_usart3_cnt = 0;   // 清空
				}
				else if (d == '#') // 正常控制字符遇到结束符 '#'
				{
					g_usart3_buf[g_usart3_cnt] = '\0'; // 拼装 C 语言字符串结束符
					g_usart3_ready = 1; // 【流向】：摇起无线接收红旗，指示前台解析
				}
			}
			else
			{
				g_usart3_cnt = 0; // 溢出防御
			}
		}
		USART_ClearITPendingBit(USART3, USART_IT_RXNE);
	}
}
```

#### 📥 步骤 2：前台调度与无线响应（`main` 轮询与 `parse_and_respond` 驱动）
无线接收红旗摇起后，前台主循环调用解析器并将应答通过无线回送手机：
```c
/* inside main() loop: */
// 数据流向：轮询到 g_usart3_ready == 1 -> 送入解析器 -> 指定回送串口为 USART3 -> 复位接收就绪
while(1)
{
	if (g_usart3_ready)
	{
		parse_and_respond((char *)g_usart3_buf, USART3); // 【流向】：送入解析，回送串口指定为 USART3
		g_usart3_cnt = 0;   // 重置
		g_usart3_ready = 0; // 复位红旗，解锁
	}
}
```

---

### 2.4 数据流向主线三：温湿度采集查询流（查询 ➔ PG9 ➔ 串口上报）

本主线实现：串口收到查询命令 `"temp?#"` ➔ 解析器识别 ➔ 启动单总线读取 ➔ `PG9` 发送低电平起始信号 ➔ DHT11 芯片响应并送出温湿度数据 ➔ `PG9` 捕获 40us 电平 ➔ 格式化并送回发起源。

#### 📥 步骤 1：触发采样与发送单总线起始信号（`dht11_read` 时序）
```c
// 数据流向：PG9 置为推挽输出 -> PGout(9)=0 强拉低18ms -> PGout(9)=1 释放 -> PG9 切换为输入模式监听
int32_t dht11_read(uint8_t *buf)
{
	uint32_t t = 0;
	int32_t i, j;
	uint8_t d = 0;
	uint8_t *p = buf; // 指针 p 指向传入的 5 字节缓冲接收空间
	
	// 1. 先切换 PG9 为推挽输出，准备控线向传感器发起请求
	GPIO_InitStructure.GPIO_Pin = GPIO_Pin_9;
	GPIO_InitStructure.GPIO_Mode = GPIO_Mode_OUT;
	GPIO_InitStructure.GPIO_OType = GPIO_OType_OD;
	GPIO_Init(GPIOG, &GPIO_InitStructure);	
	
	// 【流向】：向总线倾泻 18ms 低电平，唤醒休眠的传感器芯片
	PGout(9) = 0;
	delay_ms(18);
	PGout(9) = 1; // 【流向】：拉高释放总线，让出控制权
	delay_us(30);
	
	// 2. 迅速切换为输入模式，准备读取传感器电平数据流
	GPIO_InitStructure.GPIO_Pin = GPIO_Pin_9;
	GPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN;
	GPIO_Init(GPIOG, &GPIO_InitStructure);	

	// [握手阶段省略...] 传感器会先拉低 80us，再拉高 80us 作为应答响应
```

#### 📥 步骤 2：捕获与解析数据流位宽（`dht11_read` 40us 精准位读取）
```c
	// 3. 串行接收数据流：读取 5 个字节 (40 bits)
	for(j = 0; j < 5; j++)
	{
		d = 0;
		for(i = 7; i >= 0; i--)
		{
			t = 0;
			while(PGin(9) == 0) // 等待引脚变高电平（即位起始点）
			{
				t++;
				delay_us(1);
				if(t >= 100) return -4;
			}

			// 【流向与时间窗口判断】：高电平开始传输后，延时 40us 读取 PGin(9) 的物理电压
			delay_us(40);
			if(PGin(9)) // 如果 40us 后引脚依然是高电平，证明高电平宽达 70us，即逻辑 1
			{
				d |= 1 << i; // 【流向】：将位 1 拼入局部字节 d 中
				t = 0;
				while(PGin(9)) // 自旋等待高电平结束
				{
					t++;
					delay_us(1);
					if(t >= 100) return -5;
				}			
			}
			// 如果 40us 后引脚已降为低电平，说明之前脉宽只有 26us（代表逻辑 0），d 对应位维持默认的 0
		}	
		p[j] = d; // 【流向】：把接收满的 1 字节流入传入的缓冲中
	}
	
	// [校验和校验...] 正确返回 0
	return 0;
}
```

#### 📥 步骤 3：数据汇聚与回送（`parse_and_respond` 转换温湿度上报）
```c
/* inside parse_and_respond(): */
// 数据流向：匹配 temp?# -> 调用 dht11_read -> 提取整数与小数部分 -> 换算浮点 -> sprintf 格式化 -> 回送串口
else if (strcmp(cmd, "temp?#") == 0)
{
	uint8_t dht_buf[5]; // 开辟 5 字节缓冲
	float temp_val = 32.0; // 预置 32.0 降级 Mock 值做防线
	
	if (dht11_read(dht_buf) == 0) // 【流向】：温湿度硬件引脚数据流入 dht_buf
	{
		// 【流向】：dht_buf[2]（温度整数）与 dht_buf[3]（温度小数）进行浮点合成，流入 temp_val
		temp_val = dht_buf[2] + dht_buf[3] / 10.0;
	}
	
	sprintf(resp_buf, "%.1f\r\n", temp_val); // 【流向】：温度浮点数值转换为格式化文本流入 resp_buf
	usart_send_string(respond_port, (uint8_t *)resp_buf); // 【流向】：发送给指定串口 TX，呈现在调试助手上
}
```

---

### 2.5 数据流向主线四：蓝牙连接指示流（双向指示灯 D4 亮灭）

本主线实现：手机连接/断开蓝牙 ➔
*   **【硬件流】** STATE 引脚输出高/低 ➔ `PE6` 双边沿 EXTI 中断触发 ➔ `EXTI9_5_IRQHandler` ➔ 位带操作 `PEout(14)` 控制灯。
*   **【软件流 (防STATE未接) 】** 串口 3 收到 `OK+CONN` / `OK+LOST` ➔ 拦截机制 ➔ 直接位带写 `PEout(14)` ➔ 重置计数器并丢弃该状态包。

#### 📥 支流 A：硬件电平流向（`state_exti_init` 配置 & `EXTI9_5_IRQHandler` 中断）
```c
// 1. 初始化配置：PE6 输入模式，下拉防止电平悬空漂移，EXTI 双边沿检测
void state_exti_init(void)
{
	RCC_APB2PeriphClockCmd(RCC_APB2Periph_SYSCFG, ENABLE);
	RCC_AHB1PeriphClockCmd(RCC_AHB1Periph_GPIOE, ENABLE);

	GPIO_InitStructure.GPIO_Pin = GPIO_Pin_6;
	GPIO_InitStructure.GPIO_Mode = GPIO_Mode_IN; // 配置为电平输入
	GPIO_InitStructure.GPIO_PuPd = GPIO_PuPd_DOWN; // 配置内部下拉，悬空时强拉为低电平（0V）
	GPIO_Init(GPIOE, &GPIO_InitStructure);

	SYSCFG_EXTILineConfig(EXTI_PortSourceGPIOE, EXTI_PinSource6); // 绑定 EXTI6 通道

	EXTI_InitStructure.EXTI_Line = EXTI_Line6;
	EXTI_InitStructure.EXTI_Mode = EXTI_Mode_Interrupt;
	EXTI_InitStructure.EXTI_Trigger = EXTI_Trigger_Rising_Falling; // 双边沿硬件捕获极性
	EXTI_InitStructure.EXTI_LineCmd = ENABLE;
	EXTI_Init(&EXTI_InitStructure);
    
    // [NVIC中断通道使能省略...]
}

// 2. 数据流向：PE6电平发生跳变 -> 触发 EXTI6 中断 -> 位带读 PEin(6) -> 位带控制 PEout(14) 物理高低电平控制D4
void EXTI9_5_IRQHandler(void)
{
	if(EXTI_GetITStatus(EXTI_Line6) != RESET)
	{
		if(PEin(6) == 1) // 【流向】：如果 PE6 输入为高电平（代表蓝牙已成功物理连接）
		{
			PEout(14) = 0; // 【流向】：输出置低电平，物理点亮 D4 连接灯（低电平亮）
		}
		else // 如果 PE6 输入为低电平（代表蓝牙断开或悬空）
		{
			PEout(14) = 1; // 【流向】：输出置高电平，物理熄灭 D4 连接灯
		}
		EXTI_ClearITPendingBit(EXTI_Line6); // 清除中断标志，防卡死
	}
}
```

#### 📥 支流 B：软件数据拦截流向（`USART3_IRQHandler` 接收中途拦截）
即使没有连接 STATE 引脚线，只要串口上发生了电平变化通知，软件双保险过滤器就能百分之百捕捉并处理：
```c
/* inside USART3_IRQHandler(): */
// 数据流向：蓝牙串口收到字节拼入缓冲区 -> 临时补 \0 形成合法串 -> strstr 判定 -> 匹配 OK+LOST 或 OK+CONN 
// 数据流向：直接位带改写 PEout(14) 控制 D4 -> 将计数器强行重置为 0，数据流直接被丢弃（免得进入命令解析）
if (g_usart3_ready == 0)
{
	if (g_usart3_cnt < sizeof(g_usart3_buf) - 1)
	{
		g_usart3_buf[g_usart3_cnt++] = d; // 追加单字节
		
		g_usart3_buf[g_usart3_cnt] = '\0'; // 【流向】：临时补字符串终止符，使 strstr 可以安全逐字检索
		
		// 【流向】：如果缓冲区接收字中匹配到了 "OK+LOST" 状态字
		if (strstr((char *)g_usart3_buf, "OK+LOST") != NULL)
		{
			PEout(14) = 1;      // 【流向】：直接位带控制，拉高 PE14（熄灭 D4 灯）
			g_usart3_cnt = 0;   // 【流向】：写指针瞬间归零，直接在中断内拦截丢弃当前缓存内容！
		}
		// 【流向】：如果缓冲区接收字中匹配到了 "OK+CONN" 状态字
		else if (strstr((char *)g_usart3_buf, "OK+CONN") != NULL)
		{
			PEout(14) = 0;      // 【流向】：直接位带控制，拉低 PE14（点亮 D4 灯）
			g_usart3_cnt = 0;   // 【流向】：写指针瞬间归零，直接在中断内拦截丢弃当前缓存内容！
		}
        // ... (后面正常遇到 '#' 封包)
	}
}
```

---

## 📈 第三部分：数学算法与关键参数计算总结

在调试中，老大可以直接对照以下核心参数指标：

1.  **PWM 脉频与计数精度**：
    PWM频率 = 84MHz / ((Prescaler + 1) * (Period + 1)) = 84,000,000 / (84 * 100) = 10,000Hz = 10kHz
2.  **LED 极性映射**：
    *   `TIM_OCPolarity` 为 `TIM_OCPolarity_Low`（低电平点亮 LED 灯）。
    *   此时：
        CCR1 = 0 -> 0% 亮度 (全灭)
        CCR1 = 50 -> 50% 亮度
        CCR1 = 100 -> 100% 亮度 (全亮)
3.  **DHT11 时序判定**：
    *   高电平持续 26-28us 代表逻辑 0。
    *   高电平持续 70us 代表逻辑 1。
    *   触发检测 40us 后读取为 0 代表逻辑 0，读取为 1 代表逻辑 1。
